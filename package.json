{
  "name": "my-playwright-project",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Sample Playwright project for Portfolio",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui",
    "test:api": "playwright test --project=api",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "playwright install --with-deps"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.2.0",
    "@playwright/test": "^1.56.1",
    "@types/mssql": "^9.1.8",
    "@types/node": "^24.5.2",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "cross-env": "7.0.3",
    "dotenv": "^17.2.3",
    "eslint": "^10.0.3",
    "eslint-plugin-playwright": "^2.9.0",
    "globals": "^17.4.0",
    "prettier": "3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "decimal.js": "^10.6.0",
    "mssql": "^11.0.1",
    "winston": "^3.8.2",
    "zod": "^4.3.6"
  },
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
